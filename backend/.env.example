# ── Railway sets these automatically ──────────────────────────────────────────
PORT=4000

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex

# ── Turso database ─────────────────────────────────────────────────────────────
# Get from: turso.tech → your db → Connect → URL + Token
TURSO_URL=libsql://your-db-name-yourname.turso.io
TURSO_TOKEN=eyJhbGci...your_turso_token

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Array of phone numbers you manage
# Get phoneId + token from developers.facebook.com → WhatsApp → API Setup
WHATSAPP_NUMBERS=[{"phoneId":"123456789012345","token":"EAAB...","verifyToken":"pick_any_secret","lang":"PL"},{"phoneId":"987654321098765","token":"EAAB...","verifyToken":"pick_any_secret","lang":"HU"}]

# ── Viber ─────────────────────────────────────────────────────────────────────
# Get token from partners.viber.com → your bot → Auth Token
VIBER_BOTS=[{"token":"your-viber-pl-token","lang":"PL"},{"token":"your-viber-hu-token","lang":"HU"}]

# ── Facebook Messenger ────────────────────────────────────────────────────────
FB_PAGE_ACCESS_TOKEN=EAABwzLixnjYBO...
FB_VERIFY_TOKEN=pick_any_string_here
FB_APP_SECRET=your_app_secret_from_meta_dashboard

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
